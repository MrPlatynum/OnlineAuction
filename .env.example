# Required. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
AUCTION_SECRET_KEY=
LEGACY_PASSWORD_KEYS=

# Postgres connection. The default port is 5433 because docker-compose.yml
# maps the container's 5432 to host 5433 (the Windows native Postgres
# install on the dev machine already owns 5432). Adjust if you don't have
# that conflict.
# App uses asyncpg (async driver); Alembic auto-derives the +psycopg2 sync URL.
DATABASE_URL=postgresql+asyncpg://auction:auction_dev_password@localhost:5433/auction

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=Лотус <noreply@example.com>

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:8000,null

# Rate limiting. Defaults to enabled. Set to ``false`` only for local
# benchmarks or smoke runs that need to flood endpoints intentionally.
AUCTION_RATE_LIMIT_ENABLED=true
